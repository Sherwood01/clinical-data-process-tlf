FROM python:3.12-slim

WORKDIR /app

# Install system dependencies for pyreadstat, numpy, etc.
RUN apt-get update \
    && apt-get install -y build-essential libopenblas-dev \
    && rm -rf /var/lib/apt/lists/*

COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ /app/backend/
COPY src/ /app/src/

EXPOSE 8080

# Use more workers for production
CMD uvicorn backend.api.main:app --host 0.0.0.0 --port ${PORT:-8080} --workers 2
